<view class="page">
  <view class="hero">
    <view class="title">分享记录</view>
    <view class="subtitle">选一条一键再分享给别人，内容不变</view>
  </view>

  <view wx:if="{{loading}}" class="tip">加载中…</view>

  <view wx:elif="{{empty}}" class="empty-state">
    <view class="empty-icon">📤</view>
    <view class="empty-title">还没有分享记录</view>
    <view class="empty-desc">在菜单页点「分享」，勾选要给对方的菜分享出去，就会出现在这里</view>
  </view>

  <view wx:else>
    <view wx:for="{{shares}}" wx:key="key" class="share-card">
      <view class="share-top">
        <view class="share-count">{{item.count}} 道菜</view>
        <view class="share-time">{{item.timeText}}</view>
      </view>
      <view class="share-names">{{item.names}}</view>
      <button class="reshare-btn" open-type="share" bindtap="onReShare" data-key="{{item.key}}">再分享</button>
    </view>
  </view>
</view>
