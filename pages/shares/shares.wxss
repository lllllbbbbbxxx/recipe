page { background: var(--bg); }
.page { min-height: 100vh; background: var(--bg); padding: var(--sp-m) var(--sp-l) 60rpx; box-sizing: border-box; }

.hero { padding: var(--sp-s) 0 var(--sp-l); }
.title { font-size: 40rpx; font-weight: 700; color: var(--text); letter-spacing: -0.6rpx; }
.subtitle { font-size: 24rpx; color: var(--text-3); margin-top: var(--sp-s); }

.tip { text-align: center; color: var(--text-3); font-size: 26rpx; padding: 80rpx 0; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx var(--sp-l); }
.empty-icon { font-size: 72rpx; margin-bottom: var(--sp-m); }
.empty-title { font-size: 30rpx; font-weight: 700; color: var(--text); margin-bottom: var(--sp-s); }
.empty-desc { font-size: 24rpx; color: var(--text-3); text-align: center; line-height: 40rpx; }

.share-card {
  background: var(--card-w); border-radius: var(--r-md);
  padding: var(--sp-l); margin-bottom: var(--sp-m); box-sizing: border-box;
  box-shadow: 0 1rpx 3rpx rgba(28,26,22,.06);
}
.share-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--sp-s); }
.share-count { font-size: 27rpx; font-weight: 700; color: var(--text); }
.share-time { font-size: 21rpx; color: var(--text-3); }
.share-names { font-size: 24rpx; color: var(--text-2); line-height: 1.6; margin-bottom: var(--sp-m); }
.reshare-btn {
  margin: 0; padding: 0;
  display: flex; align-items: center; justify-content: center;
  height: 68rpx; line-height: 1;
  background: var(--primary); color: #fff; border-radius: var(--r-sm);
  font-size: 25rpx; font-weight: 600;
}
.reshare-btn::after { border: none; }
