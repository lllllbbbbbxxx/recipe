.page { min-height: 100vh; background: var(--bg); padding: var(--sp-l) var(--sp-l) 60rpx; box-sizing: border-box; }

/* ── 加载 / 失败 ── */
.loading { text-align: center; color: var(--text-3); font-size: 28rpx; padding: 160rpx 0; }

/* ── 提交成功 ── */
.success-page {
  display: flex; flex-direction: column; align-items: center;
  padding: 140rpx var(--sp-l);
}
.success-icon {
  width: 120rpx; height: 120rpx; line-height: 120rpx; text-align: center;
  border-radius: 50%; background: var(--primary); color: #fff;
  font-size: 64rpx; margin-bottom: var(--sp-l);
}
.success-title { font-size: 34rpx; font-weight: 700; color: var(--text); margin-bottom: var(--sp-s); }
.success-desc  { font-size: 25rpx; color: var(--text-2); text-align: center; line-height: 40rpx; }

/* ── 头部卡片 ── */
.header-card {
  background: var(--primary);
  border-radius: var(--r-md);
  padding: var(--sp-l);
  margin-bottom: var(--sp-m);
  box-shadow: 0 6rpx 20rpx rgba(79,107,82,.25);
  display: flex; align-items: center; gap: var(--sp-m);
}
.header-left { flex: 1; min-width: 0; }
.header-title { font-size: 38rpx; font-weight: 700; color: #fff; }
.header-desc  { font-size: 24rpx; color: rgba(255,255,255,.8); margin-top: var(--sp-s); }
/* 标题卡右侧「我的点单」入口 */
.my-orders-entry {
  flex-shrink: 0; display: flex; align-items: center; gap: 6rpx;
  height: 60rpx; padding: 0 var(--sp-m);
  background: rgba(255,255,255,.2); color: #fff;
  border-radius: 30rpx; font-size: 24rpx; font-weight: 600;
}
.mo-count {
  min-width: 30rpx; height: 30rpx; line-height: 30rpx; text-align: center;
  background: #fff; color: var(--primary); border-radius: 15rpx;
  font-size: 20rpx; padding: 0 6rpx;
}

/* ── 我的点单 弹层 ── */
.mo-mask { position: fixed; inset: 0; z-index: 300; background: rgba(0,0,0,.46); display: flex; align-items: flex-end; }
.mo-sheet {
  width: 100%; background: var(--card-w);
  border-radius: var(--r-lg) var(--r-lg) 0 0;
  padding: var(--sp-l) var(--sp-l) 40rpx; box-sizing: border-box;
  max-height: 74vh; display: flex; flex-direction: column;
}
.mo-sheet-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--sp-s); }
.mo-sheet-title { font-size: 30rpx; font-weight: 700; color: var(--text); }
.mo-sheet-close { font-size: 30rpx; color: var(--text-3); padding: 0 var(--sp-s); }
.mo-scroll { flex: 1; overflow-y: auto; }
.my-order { display: flex; align-items: center; gap: var(--sp-m); padding: var(--sp-m) 0; border-bottom: 1rpx solid var(--border-2); }
.my-order:last-child { border-bottom: none; }
.my-order-main { flex: 1; min-width: 0; }
.my-order-dishes { font-size: 26rpx; color: var(--text); font-weight: 500; }
.my-order-meta { font-size: 21rpx; color: var(--text-3); margin-top: 4rpx; }
.my-order-actions { display: flex; gap: var(--sp-m); flex-shrink: 0; }
.mo-edit { font-size: 24rpx; color: var(--primary); font-weight: 600; }
.mo-del { font-size: 24rpx; color: var(--danger); }

.cancel-edit { text-align: center; font-size: 24rpx; color: var(--text-3); margin-top: var(--sp-m); }

/* ── 菜品列表 ── */
.dish-list { display: flex; flex-direction: column; gap: var(--sp-s); margin-bottom: var(--sp-m); }
.dish-item {
  display: flex; align-items: center; gap: var(--sp-m);
  background: var(--card-w); border-radius: var(--r-md);
  padding: var(--sp-m) var(--sp-l); box-sizing: border-box;
  box-shadow: 0 1rpx 3rpx rgba(43,40,35,.06);
}
.dish-item.selected { background: var(--primary-bg); }

.dish-check {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--bg); display: flex; align-items: center; justify-content: center;
  color: transparent; font-size: 22rpx; flex-shrink: 0; box-sizing: border-box;
}
.dish-check.on { background: var(--primary); color: #fff; }

.dish-info { flex: 1; min-width: 0; }
.dish-info .dish-name { font-size: 28rpx; font-weight: 600; color: var(--text); }
.dish-sub { font-size: 22rpx; color: var(--text-3); margin-top: 4rpx; }
.dish-tags { display: flex; flex-wrap: wrap; gap: var(--sp-s); margin-top: var(--sp-s); }
.dish-tag {
  height: 32rpx; line-height: 32rpx; padding: 0 var(--sp-s);
  border-radius: 16rpx; background: var(--bg);
  color: var(--text-2); font-size: 20rpx; font-weight: 500;
}

/* ── 信息表单 ── */
.form-card {
  background: var(--card-w); border-radius: var(--r-md);
  padding: var(--sp-l); box-sizing: border-box;
  box-shadow: 0 1rpx 0 var(--border-2), 0 2rpx 8rpx rgba(43,40,35,.05);
}
.form-title { font-size: 28rpx; font-weight: 700; color: var(--text); margin-bottom: var(--sp-m); }

/* 头像 + 昵称 一行 */
.identity-row { display: flex; align-items: center; gap: var(--sp-m); margin-bottom: var(--sp-s); }
.avatar-btn {
  width: 96rpx !important; height: 96rpx; min-width: 0; flex-shrink: 0;
  padding: 0 !important; margin: 0;
  border-radius: 50%; overflow: hidden; background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  line-height: normal;
}
.avatar-btn::after { border: none; }
.avatar-img { width: 96rpx; height: 96rpx; display: block; }
.avatar-placeholder {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  color: var(--text-3); font-size: 32rpx; line-height: 1.1;
}
.avatar-tip { font-size: 18rpx; margin-top: 2rpx; }
.identity-name { flex: 1; margin-bottom: 0 !important; }
.form-input {
  width: 100%; height: 80rpx; padding: 0 var(--sp-m);
  background: var(--bg); border-radius: var(--r-sm);
  font-size: 28rpx; color: var(--text); box-sizing: border-box;
  margin-bottom: var(--sp-s);
}
.form-textarea {
  width: 100%; min-height: 140rpx; padding: var(--sp-m);
  background: var(--bg); border-radius: var(--r-sm);
  font-size: 27rpx; color: var(--text); box-sizing: border-box;
  line-height: 1.65; margin-bottom: var(--sp-m);
}
.selected-summary {
  font-size: 24rpx; color: var(--primary); font-weight: 600;
  margin-bottom: var(--sp-m);
}
.submit-btn {
  height: 92rpx; line-height: 92rpx; text-align: center;
  background: var(--primary); color: #fff;
  border-radius: var(--r-md); font-size: 30rpx; font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(79,107,82,.3);
}
.submit-btn.disabled { background: var(--text-3); box-shadow: none; }
