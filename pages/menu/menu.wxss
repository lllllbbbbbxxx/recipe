.page { min-height: 100vh; background: var(--bg); padding-bottom: 160rpx; box-sizing: border-box; }

/* ── Header ── */
.shop-header {
  background: var(--bg);
  padding: var(--sp-m) var(--sp-l) 0;
}

.shop-row {
  display: flex; align-items: flex-end; justify-content: space-between;
}

.brand { flex: 1; min-width: 0; }
/* iOS Large Title 风格 */
.shop-name {
  font-size: 40rpx; font-weight: 700; color: var(--text);
  letter-spacing: -0.8rpx;
}
/* iOS section subhead — 全大写细标注 */
.shop-desc {
  font-size: 20rpx; font-weight: 500; color: var(--text-3);
  letter-spacing: 5rpx; margin-top: 4rpx; text-transform: uppercase;
}

.header-actions { display: flex; gap: 10rpx; align-items: center; }

/* iOS tinted pill button */
.hbtn {
  height: 56rpx; line-height: 56rpx; padding: 0 16rpx;
  font-size: 24rpx; font-weight: 600;
  border-radius: 28rpx; box-sizing: border-box;
}
.hbtn-add    { background: var(--primary);    color: #fff; }
.hbtn-fridge { background: var(--primary-bg); color: var(--primary); }
.hbtn-orders { background: var(--bg2);        color: var(--text-2); }
/* 分享按钮（微信 button，需重置默认样式） */
.hbtn-share {
  display: inline-flex; align-items: center; justify-content: center;
  line-height: 1; margin: 0;
  background: var(--amber-bg); color: var(--amber);
}
.hbtn-share::after { border: none; }

/* ── 描线插画 ── */
.deco-wrap { margin: var(--sp-m) 0 var(--sp-s); overflow: hidden; }
.deco-svg  { width: 100%; height: 68rpx; display: block; }

/* ── 搜索框  (iOS Search Bar 风格) ── */
.search-bar { height: 72rpx; margin-bottom: var(--sp-s); }
.search-input {
  width: 100%; height: 72rpx;
  background: var(--card-w);
  border-radius: 20rpx;
  padding: 0 var(--sp-l);
  font-size: 28rpx; color: var(--text);
  box-sizing: border-box;
  box-shadow: 0 1rpx 0 var(--border-2);
}

/* 一键导入家常菜 入口 banner */
.import-banner {
  display: flex; align-items: center; gap: var(--sp-m);
  padding: var(--sp-m);
  margin-bottom: var(--sp-m);
  background: var(--primary-bg);
  border-radius: var(--r-md);
  border: 1rpx dashed var(--primary);
}
.import-banner-icon { font-size: 44rpx; flex-shrink: 0; }
.import-banner-text { flex: 1; min-width: 0; }
.import-banner-title { font-size: 27rpx; font-weight: 700; color: var(--primary-dk); }
.import-banner-sub { font-size: 21rpx; color: var(--primary); margin-top: 3rpx; }
.import-banner-go {
  flex-shrink: 0; height: 52rpx; line-height: 52rpx; padding: 0 var(--sp-l);
  background: var(--primary); color: #fff; border-radius: 26rpx;
  font-size: 24rpx; font-weight: 600;
}

/* 导入家常菜 引导弹层 */
.guide-mask {
  position: fixed; inset: 0; z-index: 300;
  background: rgba(0,0,0,.46); display: flex; align-items: flex-end;
}
.guide-panel {
  width: 100%; background: var(--card-w);
  border-radius: var(--r-lg) var(--r-lg) 0 0;
  padding: var(--sp-l) var(--sp-l) 40rpx; box-sizing: border-box;
  max-height: 82vh; display: flex; flex-direction: column;
}
.guide-panel::before {
  content: ''; display: block; width: 72rpx; height: 6rpx; border-radius: 3rpx;
  background: rgba(60,60,67,.2); margin: 0 auto var(--sp-l);
}
.guide-title { font-size: 30rpx; font-weight: 700; color: var(--text); }
.guide-sub { font-size: 22rpx; color: var(--text-3); margin: 4rpx 0 var(--sp-m); }
.guide-scroll { flex: 1; overflow-y: auto; }
.guide-dish {
  display: flex; align-items: center; gap: var(--sp-m);
  padding: var(--sp-m) 0; border-bottom: 1rpx solid var(--border-2);
}
.guide-dish.exists { opacity: .5; }
.guide-check {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--bg); display: flex; align-items: center; justify-content: center;
  color: transparent; font-size: 22rpx; flex-shrink: 0; box-sizing: border-box;
}
.guide-check.on { background: var(--primary); color: #fff; }
.guide-dish-info { flex: 1; min-width: 0; }
.guide-dish-name { font-size: 28rpx; font-weight: 600; color: var(--text); }
.guide-exists-tag {
  margin-left: var(--sp-s); font-size: 19rpx; font-weight: 400; color: var(--text-3);
  background: var(--bg2); border-radius: 8rpx; padding: 2rpx 10rpx;
}
.guide-dish-sub { font-size: 21rpx; color: var(--text-3); margin-top: 4rpx; }
.guide-actions { display: flex; gap: var(--sp-m); margin-top: var(--sp-m); flex-shrink: 0; }
.guide-cancel {
  flex: 1; height: 80rpx; line-height: 80rpx; text-align: center;
  background: var(--bg); border-radius: var(--r-md); color: var(--text-2); font-size: 27rpx;
}
.guide-confirm {
  flex: 2; height: 80rpx; line-height: 80rpx; text-align: center;
  background: var(--primary); color: #fff; border-radius: var(--r-md);
  font-size: 27rpx; font-weight: 600;
}

/* 分享菜单面板额外样式 */
.share-sheet-head { display: flex; align-items: flex-start; justify-content: space-between; }
.share-all-btn {
  flex-shrink: 0; height: 52rpx; line-height: 52rpx; padding: 0 var(--sp-m);
  background: var(--primary-bg); color: var(--primary);
  border-radius: 26rpx; font-size: 23rpx; font-weight: 600;
}
.share-sheet-actions { display: flex; gap: var(--sp-m); margin-top: var(--sp-m); flex-shrink: 0; }
.share-confirm {
  flex: 2; margin: 0; padding: 0;
  display: flex; align-items: center; justify-content: center;
  height: 80rpx; line-height: 1;
  background: var(--primary); color: #fff; border-radius: var(--r-md);
  font-size: 27rpx; font-weight: 600;
}
.share-confirm::after { border: none; }

/* 我的点单 弹层行 */
.mine-order { display: flex; align-items: center; gap: var(--sp-m); padding: var(--sp-m) 0; border-bottom: 1rpx solid var(--border-2); }
.mine-order:last-child { border-bottom: none; }
.mine-order-main { flex: 1; min-width: 0; }
.mine-order-dishes { font-size: 27rpx; color: var(--text); font-weight: 500; }
.mine-order-meta { font-size: 21rpx; color: var(--text-3); margin-top: 4rpx; }
.mine-order-del { flex-shrink: 0; font-size: 24rpx; color: var(--danger); }
.mine-empty { text-align: center; color: var(--text-3); font-size: 26rpx; padding: var(--sp-xl) 0; }

/* 列表底部入口 */
.list-footer { padding: var(--sp-m) 0 var(--sp-s); display: flex; gap: var(--sp-m); justify-content: center; }
.footer-backup {
  font-size: 24rpx; color: var(--text-3); font-weight: 500;
  padding: var(--sp-s) var(--sp-l); border-radius: 999rpx;
  background: var(--card-w);
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,.06);
}

/* ── 决策栏 ── */
.decision-bar {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: var(--sp-m); padding: var(--sp-m) var(--sp-l);
  background: var(--bg);
  border-top: 1rpx solid var(--border-2);
  border-bottom: 1rpx solid var(--border-2);
}

.decision-btn {
  height: 76rpx; line-height: 76rpx;
  border-radius: 20rpx;
  background: var(--card-w);
  color: var(--text-2); font-size: 28rpx; font-weight: 600;
  text-align: center; box-sizing: border-box;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,.08);
}
.primary-decision {
  background: var(--primary); color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(79,107,82,.3);
}

/* ── 临期提醒 ── */
.reminder-bar {
  display: flex; align-items: center; gap: var(--sp-s);
  padding: var(--sp-m) var(--sp-l);
  background: var(--amber-bg);
  border-bottom: 1rpx solid rgba(255,149,0,.15);
}
.reminder-dot  { width: 8rpx; height: 8rpx; border-radius: 50%; background: var(--amber); flex-shrink: 0; }
.reminder-text { font-size: 25rpx; color: var(--amber); font-weight: 500; }

/* ── 主布局 ── */
.order-layout {
  display: grid;
  grid-template-columns: 152rpx minmax(0, 1fr);
  height: calc(100vh - 400rpx);
  min-height: 520rpx;
}

/* ── 分类列 ── */
.category-list {
  height: 100%; background: var(--bg);
  border-right: 1rpx solid var(--border-2);
  overflow-y: auto;
}
.category-item {
  position: relative;
  min-height: 96rpx;
  display: flex; align-items: center; justify-content: center;
  padding: 0 var(--sp-m); text-align: center;
  /* iOS Body — 非选中态用 secondaryLabel */
  color: var(--text-2); font-size: 26rpx; font-weight: 400;
  box-sizing: border-box;
}
.category-active {
  background: var(--card-w);
  /* iOS: 选中用 label 色 + semibold */
  color: var(--text); font-weight: 600;
}
.category-marker {
  display: none; position: absolute; left: 0; top: 24rpx;
  width: 4rpx; height: 48rpx;
  background: var(--primary); border-radius: 0 4rpx 4rpx 0;
}
.category-active .category-marker { display: block; }

/* ── 菜谱列表 ── */
.dish-list {
  height: 100%; background: var(--bg);
  padding: var(--sp-m) var(--sp-m) var(--sp-xl);
  box-sizing: border-box; overflow-y: auto;
}
.empty { text-align: center; color: var(--text-3); font-size: 28rpx; padding: var(--sp-xl) 0; }

/* ── 滑动卡片容器 ── */
.swipe-item {
  position: relative; overflow: hidden;
  margin-bottom: var(--sp-m);
  border-radius: var(--r-md);
  background: var(--card-w);
  /* iOS 风格: 阴影取代边框 */
  box-shadow: 0 1rpx 0 rgba(0,0,0,.08),
              0 2rpx 10rpx rgba(0,0,0,.06);
}
.swipe-actions {
  position: absolute; top: 0; right: 0; bottom: 0;
  display: flex; width: 144rpx;
  border-radius: 0 var(--r-md) var(--r-md) 0; overflow: hidden;
}
.swipe-action {
  width: 72rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 23rpx; font-weight: 500;
}
.edit-action   { background: var(--blue); }
.delete-action { background: var(--danger); }

/* ── 菜谱卡片 ── */
.dish-card {
  position: relative; z-index: 1;
  display: flex; align-items: center; gap: var(--sp-m);
  padding: var(--sp-m);
  background: var(--card-w);
  transition: transform .18s ease;
  box-sizing: border-box;
  min-height: 152rpx;
}
.dish-card.swiped   { transform: translateX(-144rpx); }
.dish-card.selected { background: var(--primary-bg); }

/* 缩略图 */
.dish-thumb,
.dish-cover {
  width: 104rpx; height: 104rpx;
  border-radius: var(--r-sm); flex-shrink: 0;
}
.dish-cover { display: block; background: var(--bg2); }
.dish-thumb {
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 34rpx; font-weight: 700; letter-spacing: -1rpx;
}
/* 头像渐变 — 莫兰迪去饱和色，暖调统一 */
.thumb-green { background: linear-gradient(135deg,#6E8A6C,#566F54); }
.thumb-red   { background: linear-gradient(135deg,#C2705F,#A8534A); }
.thumb-blue  { background: linear-gradient(135deg,#7E97AA,#647F94); }
.thumb-light { background: linear-gradient(135deg,#8FA67E,#6E8A6C); }
.thumb-gold  { background: linear-gradient(135deg,#CF9460,#BE7A53); }

/* 菜谱信息 */
.dish-info { flex: 1; min-width: 0; }
/* iOS Headline */
.dish-name { font-size: 30rpx; font-weight: 600; color: var(--text); margin-bottom: var(--sp-s); }

/* 缺料行 — 用小圆点表示状态，省空间 */
.dish-match { display: flex; align-items: center; gap: var(--sp-s); margin-bottom: var(--sp-s); }
.match-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  flex-shrink: 0; box-sizing: border-box;
}
.match-detail { font-size: 22rpx; color: var(--text-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* 标签行 */
.dish-tags { display: flex; flex-wrap: wrap; gap: var(--sp-s); }
.dish-tag {
  height: 32rpx; line-height: 32rpx; padding: 0 10rpx;
  border-radius: 16rpx;     /* iOS pill */
  background: var(--bg);    /* 用页面底色作标签底，层次感强 */
  color: var(--text-2); font-size: 21rpx; font-weight: 500;
}
.role-tag { background: var(--primary-bg); color: var(--primary); }

/* 加入按钮 */
.add-btn {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: var(--primary-bg);
  display: flex; align-items: center; justify-content: center;
  color: var(--primary); font-size: 34rpx; font-weight: 400;
  flex-shrink: 0; align-self: center; box-sizing: border-box;
}
.add-btn.added {
  background: var(--primary); color: #fff;
  font-size: 22rpx; font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(79,107,82,.35);
}

/* ── 购物车底栏 ── */
.cart-bar {
  position: fixed; left: var(--sp-l); right: var(--sp-l); bottom: var(--sp-l);
  height: 100rpx;
  display: flex; align-items: center; justify-content: space-between;
  background: #2B2823;           /* 暖炭深色 */
  border-radius: var(--r-lg);
  box-shadow: 0 8rpx 32rpx rgba(43,40,35,.26);
  overflow: hidden; z-index: 120;
}
.cart-summary {
  display: flex; align-items: center; flex: 1; min-width: 0;
  padding-left: var(--sp-m);
}
.cart-icon {
  width: 64rpx; height: 64rpx; line-height: 64rpx; border-radius: 50%;
  text-align: center; margin-right: var(--sp-m);
  background: var(--primary); color: #fff;
  font-size: 26rpx; font-weight: 700;
}
.cart-main { font-size: 28rpx; color: #fff; font-weight: 600; letter-spacing: 0.2rpx; }
.cart-sub  { margin-top: 2rpx; font-size: 22rpx; color: rgba(255,255,255,.45); }
.checkout-btn {
  width: 168rpx; height: 100rpx; line-height: 100rpx; text-align: center;
  background: var(--primary); color: #fff;
  font-size: 27rpx; font-weight: 600; letter-spacing: 0.3rpx;
}
.checkout-disabled { background: rgba(255,255,255,.08); color: rgba(255,255,255,.28); }

/* ── 购物车面板 ── */
.cart-panel {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--card-w);
  border-radius: var(--r-lg) var(--r-lg) 0 0;
  padding: var(--sp-l) var(--sp-l) 168rpx;
  max-height: 72vh; overflow-y: auto; z-index: 200;
  transform: translateY(100%); transition: transform .28s cubic-bezier(.32,0,.67,0);
  box-sizing: border-box;
  box-shadow: 0 -2rpx 32rpx rgba(0,0,0,.10);
}
.cart-panel.show { transform: translateY(0); transition-timing-function: cubic-bezier(.33,1,.68,1); }

.cart-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: var(--sp-m);
}
/* iOS sheet 顶部把手 */
.cart-panel::before {
  content: ''; display: block;
  width: 72rpx; height: 6rpx; border-radius: 3rpx;
  background: rgba(60,60,67,.2);
  margin: 0 auto var(--sp-l);
}

.cart-title   { font-size: 30rpx; font-weight: 700; color: var(--text); }
.cart-actions { display: flex; gap: var(--sp-l); }
.action-text  { font-size: 26rpx; color: var(--primary); font-weight: 500; }
.action-close { font-size: 28rpx; color: var(--text-3); }
.cart-empty   { text-align: center; color: var(--text-3); font-size: 28rpx; padding: var(--sp-xl) 0; }

.selected-list { display: flex; flex-wrap: wrap; gap: var(--sp-s); margin-bottom: var(--sp-m); }
.selected-item {
  display: flex; align-items: center; gap: 6rpx;
  background: var(--primary-bg); color: var(--primary);
  font-size: 25rpx; font-weight: 500;
  padding: var(--sp-s) var(--sp-m);
  border-radius: 999rpx;
}
.remove-btn { color: var(--primary); font-size: 26rpx; }

.share-disabled { opacity: .45; }

.cook-done-btn {
  margin-top: var(--sp-l); height: 84rpx; line-height: 84rpx; text-align: center;
  background: var(--primary); color: #fff;
  border-radius: var(--r-md); font-size: 28rpx; font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(79,107,82,.3);
}

/* 做完菜扣减 · 每样食材 */
.consume-item { padding: var(--sp-m) 0; border-bottom: 1rpx solid var(--border-2); }
.consume-item:last-child { border-bottom: none; }
.consume-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: var(--sp-s); }
.consume-name { font-size: 27rpx; font-weight: 600; color: var(--text); }
.consume-have { font-size: 21rpx; color: var(--text-3); }
.consume-count { display: flex; align-items: center; gap: var(--sp-s); }
.consume-label { font-size: 24rpx; color: var(--text-2); }
.consume-num {
  width: 120rpx; height: 60rpx; line-height: 60rpx; text-align: center;
  background: var(--bg); border-radius: var(--r-sm); font-size: 26rpx; color: var(--text);
}
.consume-modes { display: flex; flex-wrap: wrap; gap: var(--sp-s); align-items: center; }
.cmode {
  height: 52rpx; line-height: 52rpx; padding: 0 var(--sp-m);
  background: var(--bg); color: var(--text-2); border-radius: 26rpx;
  font-size: 23rpx; box-sizing: border-box;
}
.cmode.on { background: var(--primary); color: #fff; font-weight: 600; }
.consume-custom {
  width: 160rpx; height: 52rpx; line-height: 52rpx; padding: 0 var(--sp-m);
  background: var(--bg); border-radius: 26rpx; font-size: 23rpx; color: var(--text);
  box-sizing: border-box;
}
.consume-custom.on { background: var(--primary-bg); }
.consume-vague { font-size: 23rpx; color: var(--text-3); }

.ing-section { border-top: 1rpx solid var(--border-2); padding-top: var(--sp-m); margin-top: var(--sp-m); }
.ing-title   { font-size: 24rpx; color: var(--text-3); font-weight: 400; margin-bottom: var(--sp-m); text-transform: uppercase; letter-spacing: 1rpx; }
.ing-row     { display: flex; align-items: center; gap: var(--sp-m); padding: var(--sp-s) 0; border-bottom: 1rpx solid var(--border-2); }
.ing-dot     { width: 8rpx; height: 8rpx; border-radius: 50%; background: var(--primary); flex-shrink: 0; }
.ing-name    { flex: 1; font-size: 28rpx; color: var(--text); }
.ing-amount  { font-size: 26rpx; color: var(--text-2); }

.overlay {
  display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.40); z-index: 150;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}
.overlay.show { display: block; }
