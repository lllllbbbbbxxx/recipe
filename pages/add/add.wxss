.page { min-height: 100vh; background: var(--bg); padding: var(--sp-m) var(--sp-l) 160rpx; box-sizing: border-box; }

/* ── 分组卡片 ── */
.form-section {
  background: var(--card-w);
  border-radius: var(--r-md);
  padding: var(--sp-l);
  margin-bottom: var(--sp-m);
  box-sizing: border-box;
  box-shadow: 0 1rpx 0 var(--border-2), 0 2rpx 8rpx rgba(43,40,35,.05);
}

.section-title {
  font-size: 22rpx; font-weight: 500; color: var(--text-3);
  text-transform: uppercase; letter-spacing: 2rpx;
  margin-bottom: var(--sp-m);
}
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: var(--sp-m);
}
.section-header .section-title { margin-bottom: 0; }
.add-row { font-size: 26rpx; color: var(--primary); font-weight: 600; }

/* ── 封面 ── */
.cover-row { display: flex; gap: var(--sp-m); align-items: flex-start; }
.cover-box { width: 160rpx; height: 160rpx; flex-shrink: 0; }
.cover-image { width: 160rpx; height: 160rpx; border-radius: var(--r-sm); display: block; }
.cover-placeholder {
  width: 160rpx; height: 160rpx; border-radius: var(--r-sm);
  background: var(--bg); border: 1.5rpx dashed var(--border);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: var(--sp-s); color: var(--text-3); font-size: 22rpx;
}
.cover-plus { font-size: 48rpx; font-weight: 300; line-height: 1; }
.cover-actions { flex: 1; display: flex; flex-direction: column; gap: var(--sp-s); padding-top: var(--sp-s); }
.cover-tip { font-size: 24rpx; color: var(--text-2); }
.cover-remove { font-size: 24rpx; color: var(--danger); }

/* ── 字段 ── */
.field { }
.label { display: block; font-size: 24rpx; color: var(--text-2); font-weight: 500; margin-bottom: var(--sp-s); }
/* 必填星号 */
.req { color: var(--danger); margin-left: 4rpx; font-weight: 700; }
.input {
  width: 100%; height: 80rpx; padding: 0 var(--sp-m);
  background: var(--bg); border-radius: var(--r-sm);
  font-size: 30rpx; color: var(--text); box-sizing: border-box;
}
.auto-fill-tip { margin-top: var(--sp-s); font-size: 23rpx; color: var(--primary); }

/* ── 类型 / 标签 chip ── */
.role-list, .tag-list { display: flex; flex-wrap: wrap; gap: var(--sp-s); }
.role-chip, .tag {
  height: 60rpx; line-height: 60rpx; padding: 0 var(--sp-l);
  border-radius: 30rpx; background: var(--bg);
  color: var(--text-2); font-size: 26rpx; box-sizing: border-box;
}
.role-active, .tag-active { background: var(--primary); color: #fff; font-weight: 600; }

.custom-tag-row { display: flex; gap: var(--sp-s); margin-top: var(--sp-m); align-items: center; }
.custom-tag-input {
  flex: 1; height: 72rpx; padding: 0 var(--sp-m);
  background: var(--bg); border-radius: var(--r-sm);
  font-size: 27rpx; color: var(--text); box-sizing: border-box;
}
.custom-tag-btn {
  height: 72rpx; line-height: 72rpx; padding: 0 var(--sp-l);
  background: var(--primary-bg); color: var(--primary);
  border-radius: var(--r-sm); font-size: 26rpx; font-weight: 600;
}

/* ── 食材行 ── */
.ingredient-row { display: flex; align-items: center; gap: var(--sp-s); margin-bottom: var(--sp-s); }
.ingredient-name {
  flex: 1; height: 76rpx; padding: 0 var(--sp-m);
  background: var(--bg); border-radius: var(--r-sm);
  font-size: 28rpx; color: var(--text); box-sizing: border-box;
}
.ingredient-amount {
  width: 180rpx; height: 76rpx; padding: 0 var(--sp-m);
  background: var(--bg); border-radius: var(--r-sm);
  font-size: 28rpx; color: var(--text); box-sizing: border-box;
}
.delete-row {
  font-size: 24rpx; color: var(--danger);
  padding: 0 var(--sp-s); flex-shrink: 0;
}

/* ── 保存按钮（固定底部）── */
.save-btn {
  position: fixed; left: var(--sp-l); right: var(--sp-l); bottom: 40rpx;
  width: auto !important; max-width: none !important;
  margin: 0 !important;
  display: flex !important; align-items: center; justify-content: center;
  height: 92rpx; line-height: 1;
  background: var(--primary); color: #fff;
  border-radius: var(--r-md); font-size: 30rpx; font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(79,107,82,.3);
  z-index: 50;
}
.save-btn::after { border: none; }
