<view class="page">
  <view class="form-section">
    <view class="section-title">封面</view>
    <view class="cover-row">
      <view class="cover-box" bindtap="chooseCover">
        <image wx:if="{{coverImage}}" class="cover-image" src="{{coverImage}}" mode="aspectFill"></image>
        <view wx:else class="cover-placeholder">
          <text class="cover-plus">+</text>
          <text>上传照片</text>
        </view>
      </view>
      <view class="cover-actions">
        <text class="cover-tip">用于首页菜品封面</text>
        <text wx:if="{{coverImage}}" class="cover-remove" bindtap="removeCover">移除照片</text>
      </view>
    </view>
  </view>

  <view class="form-section">
    <view class="field">
      <text class="label">菜名<text class="req">*</text></text>
      <input class="input" placeholder="例如：糖醋排骨" placeholder-style="color: #999; font-weight: 400;" value="{{name}}" bindinput="onNameInput" />
    </view>
    <view wx:if="{{autoFillText}}" class="auto-fill-tip">{{autoFillText}}</view>
  </view>

  <view class="form-section">
    <view class="section-title">类型</view>
    <view class="role-list">
      <view
        wx:for="{{mealRoleOptions}}"
        wx:key="name"
        class="role-chip {{item.active ? 'role-active' : ''}}"
        data-role="{{item.name}}"
        bindtap="selectMealRole"
      >{{item.name}}</view>
    </view>
  </view>

  <view class="form-section">
    <view class="section-title">标签</view>
    <view class="tag-list">
      <view
        wx:for="{{tagOptions}}"
        wx:key="name"
        class="tag {{item.active ? 'tag-active' : ''}}"
        data-tag="{{item.name}}"
        bindtap="toggleTag"
      >{{item.name}}</view>
    </view>
    <view class="custom-tag-row">
      <input class="custom-tag-input" placeholder="添加新标签" placeholder-style="color: #999; font-weight: 400;" value="{{customTagName}}" bindinput="onCustomTagInput" />
      <text class="custom-tag-btn" bindtap="addCustomTag">添加</text>
    </view>
  </view>

  <view class="form-section">
    <view class="section-header">
      <text class="section-title">食材<text class="req">*</text></text>
      <text class="add-row" bindtap="addIngredient">+ 添加</text>
    </view>

    <!-- 常用调料快捷添加 -->
    <view class="seasoning-quick">
      <view
        wx:for="{{commonSeasonings}}"
        wx:key="*this"
        class="seasoning-chip"
        bindtap="quickAddSeasoning"
        data-name="{{item}}"
      >+ {{item}}</view>
    </view>

    <view wx:for="{{ingredients}}" wx:key="rowKey" class="ingredient-row">
      <input
        class="ingredient-name"
        placeholder="食材"
        placeholder-style="color: #999; font-weight: 400;"
        value="{{item.name}}"
        data-index="{{index}}"
        bindinput="onIngredientNameInput"
      />
      <input
        class="ingredient-amount"
        placeholder="用量"
        placeholder-style="color: #999; font-weight: 400;"
        value="{{item.amount}}"
        data-index="{{index}}"
        bindinput="onIngredientAmountInput"
      />
      <text class="delete-row" data-index="{{index}}" bindtap="removeIngredient">删除</text>
    </view>
  </view>

  <button class="save-btn" bindtap="saveDish">{{saveButtonText}}</button>
</view>
